<!-- ========== CARROSSEL DE DESTAQUES ========== -->
<section style="margin-bottom: var(--space-16);">

  <div style="margin-bottom: var(--space-8);">
    <p style="
      font-family: var(--font-ui);
      font-size: var(--text-xs);
      font-weight: var(--font-weight-semibold);
      letter-spacing: var(--letter-spacing-wider);
      text-transform: uppercase;
      color: var(--color-highlight);
      margin-bottom: var(--space-3);
    ">Em destaque</p>
    <h1 style="
      font-family: var(--font-display);
      font-size: var(--text-3xl);
      font-weight: var(--font-weight-bold);
      letter-spacing: var(--letter-spacing-tight);
      color: var(--text-primary);
      line-height: var(--line-height-tight);
      margin: 0;
    ">Destaques</h1>
  </div>

  <div style="position: relative;">
    <div id="carousel-track" style="
      display: flex;
      gap: var(--space-6);
      overflow-x: auto;
      scroll-behavior: smooth;
      scrollbar-width: none;
      padding-bottom: var(--space-2);
    ">
      {{#each destaques}}
      <div style="
        flex: 0 0 200px;
        background-color: var(--color-bg-secondary);
        border: var(--border-subtle);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-md);
        transition: transform var(--transition-base), box-shadow var(--transition-base);
        cursor: pointer;
      "
        onmouseover="this.style.transform='translateY(-6px)'; this.style.boxShadow='var(--shadow-xl)'"
        onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='var(--shadow-md)'"
      >
        <div style="position: relative; aspect-ratio: 2/3; overflow: hidden;">
          <img src="{{this.imagem}}" alt="{{this.titulo}}" style="width: 100%; height: 100%; object-fit: cover; display: block;">
          <div style="
            position: absolute;
            top: var(--space-3);
            left: var(--space-3);
            background: var(--gradient-gold);
            color: var(--text-inverse);
            font-family: var(--font-ui);
            font-size: var(--text-xs);
            font-weight: var(--font-weight-semibold);
            letter-spacing: var(--letter-spacing-wide);
            text-transform: uppercase;
            padding: var(--space-1) var(--space-3);
            border-radius: var(--radius-full);
          ">Destaque</div>
          <div style="position: absolute; inset: 0; background: var(--gradient-hero); pointer-events: none;"></div>
        </div>
        <div style="padding: var(--space-4);">
          <h2 style="
            font-family: var(--font-display);
            font-size: var(--text-md);
            font-weight: var(--font-weight-semibold);
            color: var(--text-primary);
            line-height: var(--line-height-snug);
            margin: 0 0 var(--space-2) 0;
          ">{{this.titulo}}</h2>
          <p style="
            font-family: var(--font-mono);
            font-size: var(--text-xs);
            color: var(--text-secondary);
            margin: 0 0 var(--space-4) 0;
          ">{{this.genero}} • {{this.ano}}</p>
          <a href="/detalhes/{{this.id}}" style="
            display: block;
            text-align: center;
            background-color: var(--color-bg-elevated);
            border: var(--border-default);
            border-radius: var(--radius-md);
            color: var(--text-primary);
            font-family: var(--font-ui);
            font-size: var(--text-xs);
            font-weight: var(--font-weight-semibold);
            letter-spacing: var(--letter-spacing-wide);
            text-transform: uppercase;
            padding: var(--space-3);
            text-decoration: none;
            transition: background var(--transition-base);
          "
            onmouseover="this.style.background='var(--color-highlight)'; this.style.color='var(--text-inverse)'"
            onmouseout="this.style.background='var(--color-bg-elevated)'; this.style.color='var(--text-primary)'"
          >Ver detalhes</a>
        </div>
      </div>
      {{/each}}
    </div>

    <!-- Botão esquerda -->
    <button onclick="document.getElementById('carousel-track').scrollBy({ left: -440, behavior: 'smooth' })" style="
      position: absolute;
      left: -20px;
      top: 40%;
      transform: translateY(-50%);
      background-color: var(--color-bg-elevated);
      border: var(--border-default);
      border-radius: var(--radius-full);
      color: var(--text-primary);
      width: 40px;
      height: 40px;
      cursor: pointer;
      font-size: 1.2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background var(--transition-base);
      z-index: 10;
    "
      onmouseover="this.style.background='var(--color-highlight)'"
      onmouseout="this.style.background='var(--color-bg-elevated)'"
    >‹</button>

    <!-- Botão direita -->
    <button onclick="document.getElementById('carousel-track').scrollBy({ left: 440, behavior: 'smooth' })" style="
      position: absolute;
      right: -20px;
      top: 40%;
      transform: translateY(-50%);
      background-color: var(--color-bg-elevated);
      border: var(--border-default);
      border-radius: var(--radius-full);
      color: var(--text-primary);
      width: 40px;
      height: 40px;
      cursor: pointer;
      font-size: 1.2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background var(--transition-base);
      z-index: 10;
    "
      onmouseover="this.style.background='var(--color-highlight)'"
      onmouseout="this.style.background='var(--color-bg-elevated)'"
    >›</button>
  </div>
</section>

<!-- ========== GRID TODOS OS FILMES ========== -->
<section>

  <div style="margin-bottom: var(--space-8);">
    <p style="
      font-family: var(--font-ui);
      font-size: var(--text-xs);
      font-weight: var(--font-weight-semibold);
      letter-spacing: var(--letter-spacing-wider);
      text-transform: uppercase;
      color: var(--color-highlight);
      margin-bottom: var(--space-3);
    ">Catálogo</p>
    <h2 style="
      font-family: var(--font-display);
      font-size: var(--text-2xl);
      font-weight: var(--font-weight-bold);
      letter-spacing: var(--letter-spacing-tight);
      color: var(--text-primary);
      line-height: var(--line-height-tight);
      margin: 0;
    ">Todos os Filmes</h2>
  </div>

  <div style="
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-6);
  ">
    {{#each movies}}
    <div style="
      background-color: var(--color-bg-secondary);
      border: var(--border-subtle);
      border-radius: var(--radius-lg);
      overflow: hidden;
      box-shadow: var(--shadow-md);
      transition: transform var(--transition-base), box-shadow var(--transition-base);
      cursor: pointer;
    "
      onmouseover="this.style.transform='translateY(-6px)'; this.style.boxShadow='var(--shadow-xl)'"
      onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='var(--shadow-md)'"
    >
      <div style="position: relative; aspect-ratio: 2/3; overflow: hidden;">
        <img src="{{this.imagem}}" alt="{{this.titulo}}" style="width: 100%; height: 100%; object-fit: cover; display: block;">
        {{#if this.destaque}}
        <div style="
          position: absolute;
          top: var(--space-3);
          left: var(--space-3);
          background: var(--gradient-gold);
          color: var(--text-inverse);
          font-family: var(--font-ui);
          font-size: var(--text-xs);
          font-weight: var(--font-weight-semibold);
          letter-spacing: var(--letter-spacing-wide);
          text-transform: uppercase;
          padding: var(--space-1) var(--space-3);
          border-radius: var(--radius-full);
        ">Destaque</div>
        {{/if}}
        <div style="position: absolute; inset: 0; background: var(--gradient-hero); pointer-events: none;"></div>
      </div>
      <div style="padding: var(--space-4);">
        <h2 style="
          font-family: var(--font-display);
          font-size: var(--text-md);
          font-weight: var(--font-weight-semibold);
          color: var(--text-primary);
          line-height: var(--line-height-snug);
          margin: 0 0 var(--space-2) 0;
        ">{{this.titulo}}</h2>
        <p style="
          font-family: var(--font-mono);
          font-size: var(--text-xs);
          color: var(--text-secondary);
          margin: 0 0 var(--space-4) 0;
        ">{{this.genero}} • {{this.ano}}</p>
        <a href="/detalhes/{{this.id}}" style="
          display: block;
          text-align: center;
          background-color: var(--color-bg-elevated);
          border: var(--border-default);
          border-radius: var(--radius-md);
          color: var(--text-primary);
          font-family: var(--font-ui);
          font-size: var(--text-xs);
          font-weight: var(--font-weight-semibold);
          letter-spacing: var(--letter-spacing-wide);
          text-transform: uppercase;
          padding: var(--space-3);
          text-decoration: none;
          transition: background var(--transition-base);
        "
          onmouseover="this.style.background='var(--color-highlight)'; this.style.color='var(--text-inverse)'"
          onmouseout="this.style.background='var(--color-bg-elevated)'; this.style.color='var(--text-primary)'"
        >Ver detalhes</a>
      </div>
    </div>
    {{/each}}
  </div>

</section>
