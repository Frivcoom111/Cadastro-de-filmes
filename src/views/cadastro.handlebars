<style>
  .form-card {
    background-color: var(--color-bg-secondary);
    border: var(--border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-12) var(--space-10);
    width: 100%;
    max-width: 520px;
    margin: var(--space-8) auto;
    box-shadow: var(--shadow-xl);
    animation: fadeUp 0.5s ease both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .form-header {
    text-align: center;
    margin-bottom: var(--space-10);
  }

  .form-header .badge-label {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wider);
    text-transform: uppercase;
    color: var(--color-highlight);
    border: var(--border-gold);
    border-radius: var(--radius-full);
    padding: var(--space-1) var(--space-4);
    margin-bottom: var(--space-4);
  }

  .form-header h1 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--letter-spacing-tight);
    color: var(--text-primary);
    line-height: var(--line-height-tight);
    margin: 0;
  }

  .form-header p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-top: var(--space-2);
  }

  .form-label {
    display: block;
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: var(--space-2);
  }

  .form-control {
    width: 100%;
    background-color: var(--color-bg-elevated);
    border: var(--border-default);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    padding: var(--space-3) var(--space-4);
    height: 46px;
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
    box-sizing: border-box;
  }

  .form-control::placeholder {
    color: var(--text-muted);
  }

  .form-control:focus {
    outline: none;
    border-color: rgba(200, 169, 110, 0.5);
    box-shadow: 0 0 0 3px rgba(200, 169, 110, 0.1);
  }

  .form-textarea {
    width: 100%;
    background-color: var(--color-bg-elevated);
    border: var(--border-default);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    padding: var(--space-3) var(--space-4);
    height: 100px;
    resize: vertical;
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
    box-sizing: border-box;
  }

  .form-textarea::placeholder {
    color: var(--text-muted);
  }

  .form-textarea:focus {
    outline: none;
    border-color: rgba(200, 169, 110, 0.5);
    box-shadow: 0 0 0 3px rgba(200, 169, 110, 0.1);
  }

  .mb-field {
    margin-bottom: var(--space-5);
  }

  .row-half {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-5);
  }

  .row-half .form-control {
    width: 100%;
  }

  .upload-area {
    background-color: var(--color-bg-elevated);
    border: 1px dashed rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-md);
    padding: var(--space-6) var(--space-4);
    text-align: center;
    cursor: pointer;
    transition: border-color var(--transition-base), background var(--transition-base);
    position: relative;
  }

  .upload-area:hover {
    border-color: rgba(200, 169, 110, 0.4);
    background-color: rgba(200, 169, 110, 0.04);
  }

  .upload-area input[type="file"] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
  }

  .upload-icon {
    font-size: 1.5rem;
    margin-bottom: var(--space-2);
    opacity: 0.5;
  }

  .upload-area p {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin: 0;
  }

  .upload-area span {
    color: var(--color-highlight);
    font-weight: var(--font-weight-medium);
  }

  .form-divider {
    border: none;
    border-top: var(--border-subtle);
    margin: var(--space-8) 0;
  }

  .btn-cadastrar {
    width: 100%;
    background: var(--color-accent);
    color: var(--text-inverse);
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    padding: var(--space-4);
    margin-top: var(--space-4);
    cursor: pointer;
    transition: background var(--transition-base), transform var(--transition-fast), box-shadow var(--transition-base);
  }

  .btn-cadastrar:hover {
    background: var(--color-highlight);
    box-shadow: var(--shadow-glow);
    transform: translateY(-1px);
  }

  .btn-cadastrar:active {
    transform: translateY(0);
  }
</style>

<div class="form-card">

  <div class="form-header">
    <div class="badge-label">Novo registro</div>
    <h1>Cadastrar Filme</h1>
    <p>Preencha as informações do filme abaixo</p>
  </div>

  <form action="/filmes/criar" method="POST" enctype="multipart/form-data">

    <!-- Título -->
    <div class="mb-field">
      <label class="form-label">Título do Filme</label>
      <input
        type="text"
        name="titulo"
        class="form-control"
        placeholder="Ex: Oppenheimer"
        required
      >
    </div>

    <!-- Poster -->
    <div class="mb-field">
      <label class="form-label">Poster do Filme</label>
      <div class="upload-area">
        <input type="file" name="imagem" accept="image/*">
        <div class="upload-icon">🎬</div>
        <p><span>Clique para enviar</span> ou arraste a imagem</p>
        <p style="margin-top: 4px;">PNG, JPG até 5MB</p>
      </div>
    </div>

    <hr class="form-divider">

    <!-- Gênero e Ano -->
    <div class="row-half">
      <div>
        <label class="form-label">Gênero</label>
        <input type="text" name="genero" class="form-control" placeholder="Ex: Drama">
      </div>
      <div>
        <label class="form-label">Ano</label>
        <input type="number" name="ano" class="form-control" placeholder="Ex: 2023" min="1888" max="2099">
      </div>
    </div>

    <!-- Diretor -->
    <div class="mb-field">
      <label class="form-label">Diretor</label>
      <input type="text" name="diretor" class="form-control" placeholder="Ex: Christopher Nolan">
    </div>

    <!-- Descrição -->
    <div class="mb-field">
      <label class="form-label">Descrição</label>
      <textarea
        name="descricao"
        class="form-textarea"
        placeholder="Breve descrição do filme..."
      ></textarea>
    </div>

    <!-- Destaque -->
    <div class="mb-field">
      <label class="form-label">Destaque</label>
      <select name="destaque" class="form-control" style="height: 46px; cursor: pointer;">
        <option value="0" style="background-color: var(--color-bg-elevated);">Não</option>
        <option value="1" style="background-color: var(--color-bg-elevated);">Sim</option>
      </select>
    </div>

    <button type="submit" class="btn-cadastrar">Cadastrar Filme</button>

  </form>

</div>
