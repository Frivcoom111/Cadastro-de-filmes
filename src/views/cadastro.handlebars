<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cadastrar Filme</title>

  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Sora:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="styles/style.css">

  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background-color: var(--color-bg-primary);
      font-family: var(--font-body);
      color: var(--text-primary);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: var(--space-8) var(--space-4);
    }

    /* ── CARD DO FORMULÁRIO ── */
    .form-card {
      background-color: var(--color-bg-secondary);
      border: var(--border-subtle);
      border-radius: var(--radius-xl);
      padding: var(--space-12) var(--space-10);
      width: 100%;
      max-width: 520px;
      box-shadow: var(--shadow-xl);
      animation: fadeUp 0.5s var(--transition-smooth) both;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── CABEÇALHO ── */
    .form-header {
      text-align: center;
      margin-bottom: var(--space-10);
    }

    .form-header .badge-label {
      display: inline-block;
      font-family: var(--font-ui);
      font-size: var(--text-xs);
      font-weight: var(--font-weight-semibold);
      letter-spacing: var(--letter-spacing-wider);
      text-transform: uppercase;
      color: var(--color-highlight);
      border: var(--border-gold);
      border-radius: var(--radius-full);
      padding: var(--space-1) var(--space-4);
      margin-bottom: var(--space-4);
    }

    .form-header h1 {
      font-family: var(--font-display);
      font-size: var(--text-3xl);
      font-weight: var(--font-weight-bold);
      letter-spacing: var(--letter-spacing-tight);
      color: var(--text-primary);
      line-height: var(--line-height-tight);
    }

    .form-header p {
      font-size: var(--text-sm);
      color: var(--text-secondary);
      margin-top: var(--space-2);
    }

    /* ── LABELS ── */
    .form-label {
      font-family: var(--font-ui);
      font-size: var(--text-xs);
      font-weight: var(--font-weight-semibold);
      letter-spacing: var(--letter-spacing-wide);
      text-transform: uppercase;
      color: var(--text-secondary);
      margin-bottom: var(--space-2);
    }

    /* ── INPUTS ── */
    .form-control {
      background-color: var(--color-bg-elevated) !important;
      border: var(--border-default) !important;
      border-radius: var(--radius-md) !important;
      color: var(--text-primary) !important;
      font-family: var(--font-body);
      font-size: var(--text-sm) !important;
      padding: var(--space-3) var(--space-4) !important;
      transition: border-color var(--transition-base), box-shadow var(--transition-base);
      height: 46px;
    }

    .form-control::placeholder {
      color: var(--text-muted) !important;
    }

    .form-control:focus {
      border-color: rgba(200, 169, 110, 0.5) !important;
      box-shadow: 0 0 0 3px rgba(200, 169, 110, 0.1) !important;
      outline: none !important;
    }

    /* ── INPUT DE IMAGEM ── */
    .upload-area {
      background-color: var(--color-bg-elevated);
      border: 1px dashed rgba(255,255,255,0.15);
      border-radius: var(--radius-md);
      padding: var(--space-6) var(--space-4);
      text-align: center;
      cursor: pointer;
      transition: border-color var(--transition-base), background var(--transition-base);
      position: relative;
    }

    .upload-area:hover {
      border-color: rgba(200, 169, 110, 0.4);
      background-color: rgba(200, 169, 110, 0.04);
    }

    .upload-area input[type="file"] {
      position: absolute;
      inset: 0;
      opacity: 0;
      cursor: pointer;
    }

    .upload-icon {
      font-size: 1.5rem;
      margin-bottom: var(--space-2);
      opacity: 0.5;
    }

    .upload-area p {
      font-size: var(--text-xs);
      color: var(--text-muted);
      margin: 0;
    }

    .upload-area span {
      color: var(--color-highlight);
      font-weight: var(--font-weight-medium);
    }

    /* ── LINHA DE 2 COLUNAS ── */
    .row-half .col {
      padding-left: var(--space-2);
      padding-right: var(--space-2);
    }

    .row-half {
      margin-left: calc(-1 * var(--space-2));
      margin-right: calc(-1 * var(--space-2));
    }

    /* ── RATING STARS ── */
    .stars-wrapper {
      display: flex;
      gap: var(--space-2);
      align-items: center;
    }

    .stars-wrapper input[type="number"] {
      flex: 1;
    }

    .nota-hint {
      font-size: var(--text-xs);
      color: var(--text-muted);
      white-space: nowrap;
    }

    /* ── BOTÃO ── */
    .btn-cadastrar {
      width: 100%;
      background: var(--color-accent);
      color: var(--text-inverse);
      border: none;
      border-radius: var(--radius-md);
      font-family: var(--font-ui);
      font-size: var(--text-sm);
      font-weight: var(--font-weight-semibold);
      letter-spacing: var(--letter-spacing-wide);
      text-transform: uppercase;
      padding: var(--space-4);
      margin-top: var(--space-4);
      transition: background var(--transition-base), transform var(--transition-fast), box-shadow var(--transition-base);
      cursor: pointer;
    }

    .btn-cadastrar:hover {
      background: var(--color-highlight);
      box-shadow: var(--shadow-glow);
      transform: translateY(-1px);
    }

    .btn-cadastrar:active {
      transform: translateY(0);
    }

    /* ── DIVIDER ── */
    .form-divider {
      border: none;
      border-top: var(--border-subtle);
      margin: var(--space-8) 0;
    }

    /* ── GRUPOS ── */
    .mb-field {
      margin-bottom: var(--space-5);
    }
  </style>
</head>
<body>

  <div class="form-card">

    <div class="form-header">
      <div class="badge-label">Novo registro</div>
      <h1>Cadastrar Filme</h1>
      <p>Preencha as informações do filme abaixo</p>
    </div>

    <form action="/filmes" method="POST" enctype="multipart/form-data">

      <!-- Título -->
      <div class="mb-field">
        <label class="form-label">Título do Filme</label>
        <input
          type="text"
          name="titulo"
          class="form-control"
          placeholder="Ex: Oppenheimer"
          required
        >
      </div>

      <!-- Imagem -->
      <div class="mb-field">
        <label class="form-label">Poster do Filme</label>
        <div class="upload-area">
          <input type="file" name="imagem" accept="image/*">
          <div class="upload-icon">🎬</div>
          <p><span>Clique para enviar</span> ou arraste a imagem</p>
          <p style="margin-top: 4px;">PNG, JPG até 5MB</p>
        </div>
      </div>

      <hr class="form-divider">

      <!-- Gênero e Ano lado a lado -->
      <div class="row row-half mb-field">
        <div class="col">
          <label class="form-label">Gênero</label>
          <input
            type="text"
            name="genero"
            class="form-control"
            placeholder="Ex: Drama"
          >
        </div>
        <div class="col">
          <label class="form-label">Ano</label>
          <input
            type="number"
            name="ano"
            class="form-control"
            placeholder="Ex: 2023"
            min="1888"
            max="2099"
          >
        </div>
      </div>

      <!-- Diretor -->
      <div class="mb-field">
        <label class="form-label">Diretor</label>
        <input
          type="text"
          name="diretor"
          class="form-control"
          placeholder="Ex: Christopher Nolan"
        >
      </div>

      <!-- Nota -->
      <div class="mb-field">
        <label class="form-label">Nota</label>
        <div class="stars-wrapper">
          <input
            type="number"
            name="nota"
            class="form-control"
            placeholder="0.0"
            min="0"
            max="10"
            step="0.1"
          >
          <span class="nota-hint">de 10</span>
        </div>
      </div>

      <!-- Botão -->
      <button type="submit" class="btn-cadastrar">
        Cadastrar Filme
      </button>

    </form>
  </div>

</body>
</html>